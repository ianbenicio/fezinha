# Fezinha — variáveis de ambiente (copie para .env e preencha)
# .env está no .gitignore. NUNCA commitar segredos.

# ── Supabase ────────────────────────────────────────────
# Projeto: fezinha (region sa-east-1)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx   # pública (frontend)
SUPABASE_SERVICE_ROLE_KEY=                              # SECRETA — painel > Settings > API
SUPABASE_PROJECT_REF=

# ── Frontend (Next.js) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# ── LLM (motor Fezinha) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ── Ingestão de dados (scraper / API esportiva) ─────────
# API-Football (api-sports.io) — key grátis em dashboard.api-football.com
API_FOOTBALL_KEY=
# Dados externos futuros
# ODDS_API_KEY=
# OPENWEATHER_KEY=
